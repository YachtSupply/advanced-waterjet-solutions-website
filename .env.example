# Boatwork API integration
BOATWORK_API_TOKEN=          # Bearer token for authenticated endpoints
BOATWORK_WEBHOOK_SECRET=     # HMAC secret for webhook signature verification

# Cron & revalidation
CRON_SECRET=                 # Secret for authenticating cron/sync calls
REVALIDATE_SECRET=           # Next.js on-demand revalidation secret

# AI content generation (build-time only, NOT in Vercel)
BOATWORK_PROFILE_SLUG=       # Contractor profile slug
ANTHROPIC_API_KEY=           # Anthropic API key (pre-build script only)

# Site
NEXT_PUBLIC_SITE_URL=        # Full deployed URL (e.g., https://marinepro.com)

# GitHub (read-only)
GITHUB_TOKEN=                # Optional, for version check endpoint

# Email
RESEND_API_KEY=              # Resend API key for contact form emails

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=  # Google Analytics ID
